# Postgres connection string — both server/ and agent/ share one database.
# On Railway, set this to the Postgres plugin's connection string. Locally,
# point it at any Postgres instance (e.g. a free Neon project for testing).
DATABASE_URL=

# LiveKit server connection (self-hosted via infra/docker-compose.yml, or a LiveKit Cloud project)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-to-a-real-32-char-secret

# Sarvam AI (STT: Saaras v3, TTS: Bulbul v3) — https://dashboard.sarvam.ai
SARVAM_API_KEY=

# ElevenLabs TTS (optional) — https://elevenlabs.io/app/settings/api-keys
# Only needed if an agent's dashboard-selected voice starts with
# "elevenlabs:"; unset, those agents silently fall back to the default
# Sarvam voice instead of erroring.
ELEVEN_API_KEY=

# LLM for the qualification conversation — set whichever provider(s) your
# agents use. The dashboard's per-agent "Model" field picks the provider by
# name prefix (gpt-*/o*-... → OpenAI, gemini-* → Gemini), so both keys can be
# set at once to A/B test providers across agents.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Tavily (https://tavily.com) — gives agents live web search for facts/news
# outside the knowledge base. Optional: the web_search tool silently no-ops
# for the LLM if this is unset.
TAVILY_API_KEY=

# --- Social login (optional) — the button only appears once a provider's
# id/secret/redirect are all set; unset providers stay silently hidden.
# APP_BASE_URL is where the browser lands after a successful OAuth login
# (your Vercel-facing app origin, e.g. https://yourapp.vercel.app).
APP_BASE_URL=
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID.
# Redirect URI must be the Vercel-facing /api path (not the raw Railway URL),
# e.g. https://yourapp.vercel.app/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App.
# Authorization callback URL, e.g. https://yourapp.vercel.app/api/auth/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=

# --- Inbound phone calls via EnableX → LiveKit SIP (optional) ---
# Public HTTPS base URL of the FastAPI backend (server/), used as the EnableX
# inbound-call webhook. Set the EnableX portal webhook to
#   <PUBLIC_WEBHOOK_HOST>/telephony/enablex/inbound-event
# This must reach the Python backend (port 8000) — a Vercel-hosted React
# frontend cannot serve it.
PUBLIC_WEBHOOK_HOST=

# LiveKit SIP endpoint calls are bridged to. Defaults to the SIP subdomain
# derived from LIVEKIT_URL (…​.livekit.cloud → …​.sip.livekit.cloud); only set
# this if your project's SIP host differs.
LIVEKIT_SIP_HOST=

# --- Call recording via Backblaze B2 (optional) ---
# Recordings are captured inside the agent process itself (agent/recording.py)
# and uploaded straight to B2 via its S3-compatible API — not LiveKit's own
# record=True/Egress, which carries a separate billed observability cost.
# Picked over Cloudflare R2 because B2's free tier (10GB, permanent) never
# requires a card on file, where R2 gates its free tier behind adding a
# payment method even at $0 due. Both server/ (for the presigned playback
# URL route) and agent/ (for the upload) need these same five values. Unset,
# the agent silently skips recording — nothing breaks.
#
# Setup: backblaze.com → sign up (no card) → B2 Cloud Storage → Create a
# Bucket (private). Then Application Keys → Add a New Application Key,
# scoped to that bucket, with Read and Write access — this gives you
# keyID (B2_KEY_ID) and applicationKey (B2_APPLICATION_KEY). The bucket's
# detail page shows its Endpoint (B2_ENDPOINT_URL, e.g.
# https://s3.us-west-004.backblazeb2.com) and Region (B2_REGION, e.g.
# us-west-004).
B2_ENDPOINT_URL=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_REGION=
